generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite enum desteklemediği için String kullanılır (değerler: ADMIN, PARENT)
// (değerler: ACTIVE, INACTIVE)

model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  password           String
  role               String   @default("PARENT")
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())

  parent Parent?
}

model Student {
  id           String   @id @default(uuid())
  schoolNumber String   @unique
  fullName     String
  className    String
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())

  parents              Parent[]             @relation("StudentParents")
  absenteeisms         Absenteeism[]
  writtenWarnings      WrittenWarning[]
  dailyViolations      DailyViolation[]
  gradeReportStudents  GradeReportStudent[]
}

model Parent {
  id       String @id @default(uuid())
  userId   String @unique
  fullName String
  phone    String

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students Student[] @relation("StudentParents")

  @@index([phone])
}

model Absenteeism {
  id             String    @id @default(uuid())
  studentId      String
  warningNumber  Int       @default(1)
  isBep          Boolean   @default(false)
  pdfPath        String
  previewPath    String?
  excusedDays    Float?
  unexcusedDays  Float?
  createdAt      DateTime  @default(now())
  viewedByParent Boolean   @default(false)
  waSentAt       DateTime?

  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}


model WrittenWarning {
  id                  String    @id @default(uuid())
  studentId           String
  warningNumber       Int       @default(1)
  behaviorCode        String
  behaviorText        String
  description         String?
  guidanceNote        String?
  classTeacherName    String?
  schoolCounselorName String?
  pdfPath             String
  issuedBy            String    @default("Okul Yönetimi")
  issuedAt            DateTime  @default(now())
  createdAt           DateTime  @default(now())
  waSentAt            DateTime?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ── Günlük İhlal Takip Sistemi ──────────────────────
// ViolationType değerleri: KIYAFET, TOREN_GEC, DIGER

model ViolationUpload {
  id          String  @id @default(uuid())
  type        String
  description String?
  imagePath   String
  ocrRawText  String?
  uploadedBy  String        @default("Okul Yönetimi")
  violationDate DateTime    @default(now())
  createdAt   DateTime      @default(now())

  records DailyViolation[]
}

model DailyViolation {
  id              String   @id @default(uuid())
  studentId       String
  uploadId        String
  type            String
  violationDate   DateTime      @default(now())
  matchedBy       String        @default("OCR")   // OCR, MANUAL
  isConfirmed     Boolean       @default(false)
  createdAt       DateTime      @default(now())

  student Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  upload  ViolationUpload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([studentId, uploadId])
  @@index([studentId])
  @@index([uploadId])
  @@index([type])
  @@index([violationDate])
}

// ── Okul Ayarları ──────────────────────────────────

model SchoolSettings {
  id             String   @id @default("singleton")
  schoolName     String   @default("")
  principalName  String   @default("")
  waTemplate1    String?  @default("")
  waTemplate2    String?  @default("")
  waTemplate3    String?  @default("")
  updatedAt      DateTime @updatedAt
}

// ── Personel ───────────────────────────────────────
// role değerleri: MUDUR_YARDIMCISI | REHBER_OGRETMEN | SINIF_REHBER_OGRETMEN

model Staff {
  id        String   @id @default(uuid())
  name      String
  role      String
  className String?  // Sadece SINIF_REHBER_OGRETMEN için (örn: "10-A")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([role])
}

// ── Karne / Akademik Başarısızlık Bildirimi ────────

model GradeReport {
  id          String   @id @default(uuid())
  className   String
  schoolYear  String
  meetingDate DateTime @default(now())
  karneText   String?  // ham çıkarılan metin (debug)
  uploadedAt  DateTime @default(now())
  archived    Boolean  @default(false)

  students GradeReportStudent[]
}

model GradeReportStudent {
  id             String   @id @default(uuid())
  reportId       String
  studentId      String?  // DB'de eşleşen öğrenci (null = eşleşme yok)
  fullName       String   // karneden okunan isim
  className      String
  tcKimlikNo     String?
  schoolNumber   String?
  failedSubjects String   // JSON: [{subject:string, grade:number}]
  pdfPath        String?  // üretilen PDF yolu
  createdAt      DateTime @default(now())

  report  GradeReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  student Student?    @relation(fields: [studentId], references: [id])

  @@index([reportId])
  @@index([studentId])
}
